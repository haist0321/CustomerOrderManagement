<Window x:Class="CustomerOrderManagement.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản lý đơn hàng"
        Height="450"
        Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#f8f8f8">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="350">

            <TextBlock Text="HỆ THỐNG QUẢN LÝ ĐƠN HÀNG"
                       FontSize="20"
                       FontWeight="Bold"
                       TextAlignment="Center"
                       Margin="0,0,0,20" />

            <Button Content="Quản lý khách hàng"
                    Height="40"
                    Margin="0,0,0,10"
                    Click="ManageCustomers_Click" />

            <Button Content="Tạo đơn hàng mới"
                    Height="40"
                    Margin="0,0,0,10"
                    Click="CreateOrder_Click" />

            <Button Content="Danh sách đơn hàng"
                    Height="40"
                    Margin="0,0,0,10"
                    Click="ViewOrders_Click" />

            <Button Content="Thống kê và Biểu đồ"
                    Height="40"
                    Margin="0,0,0,10"
                    Click="ViewStatistics_Click" />

            <Button Content="Đăng xuất"
                    Height="40"
                    Background="LightGray"
                    Click="Logout_Click" />
        </StackPanel>
    </Grid>
</Window>

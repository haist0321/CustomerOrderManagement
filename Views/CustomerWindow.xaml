<Window x:Class="CustomerOrderManagement.Views.CustomerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản lý khách hàng"
        Height="500"
        Width="700">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Form nhập -->
        <StackPanel Orientation="Horizontal"
                    Margin="0,0,0,10"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top">
            <StackPanel Margin="5">
                <Label Content="Tên" />
                <TextBox x:Name="txtName"
                         Width="120" />
            </StackPanel>
            <StackPanel Margin="5">
                <Label Content="Email" />
                <TextBox x:Name="txtEmail"
                         Width="150" />
            </StackPanel>
            <StackPanel Margin="5">
                <Label Content="SĐT" />
                <TextBox x:Name="txtPhone"
                         Width="100" />
            </StackPanel>
            <StackPanel Margin="5"
                        VerticalAlignment="Bottom">
                <Button Content="Thêm"
                        Width="60"
                        Click="AddCustomer_Click" />
            </StackPanel>
            <StackPanel Margin="5"
                        VerticalAlignment="Bottom">
                <Button Content="Sửa"
                        Width="60"
                        Click="UpdateCustomer_Click" />
            </StackPanel>
            <StackPanel Margin="5"
                        VerticalAlignment="Bottom">
                <Button Content="Xóa"
                        Width="60"
                        Click="DeleteCustomer_Click" />
            </StackPanel>
        </StackPanel>

        <!-- Thanh tìm kiếm -->
        <StackPanel Orientation="Horizontal"
                    Grid.Row="1"
                    Margin="0,0,0,10"
                    HorizontalAlignment="Left">
            <TextBox x:Name="txtSearch"
                     Width="200"
                     Margin="5"
                     KeyDown="txtSearch_KeyDown"
                     TextChanged="txtSearch_TextChanged"
                     ToolTip="Nhập tên, email hoặc số điện thoại để tìm" />
            <Button Content="Tìm"
                    Width="60"
                    Margin="5"
                    Click="SearchCustomer_Click" />
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid x:Name="customerDataGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  SelectionChanged="customerDataGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"
                                    Binding="{Binding CustomerId}"
                                    Width="Auto" />
                <DataGridTextColumn Header="Tên"
                                    Binding="{Binding Name}"
                                    Width="*" />
                <DataGridTextColumn Header="Email"
                                    Binding="{Binding Email}"
                                    Width="*" />
                <DataGridTextColumn Header="SĐT"
                                    Binding="{Binding Phone}"
                                    Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>

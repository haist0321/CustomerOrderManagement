<Window x:Class="CustomerOrderManagement.Views.OrderListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Danh sách đơn hàng"
        Height="500"
        Width="850">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal"
                    Margin="0,0,0,10">
            <Button Content="Sửa"
                    Width="80"
                    Margin="5"
                    Click="EditOrder_Click" />
            <Button Content="Xóa"
                    Width="80"
                    Margin="5"
                    Click="DeleteOrder_Click" />
        </StackPanel>

        <DataGrid x:Name="orderDataGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã đơn"
                                    Binding="{Binding OrderId}"
                                    Width="Auto" />
                <DataGridTextColumn Header="Khách hàng"
                                    Binding="{Binding Customer.Name}"
                                    Width="*" />
                <DataGridTextColumn Header="Loại đơn"
                                    Binding="{Binding OrderType}"
                                    Width="*" />
                <DataGridTextColumn Header="Ngày đặt"
                                    Binding="{Binding OrderDate}"
                                    Width="*" />
                <DataGridTextColumn Header="Tổng tiền"
                                    Binding="{Binding TotalAmount}"
                                    Width="*" />
                <DataGridTextColumn Header="Giảm giá"
                                    Binding="{Binding Discount}"
                                    Width="*" />
                <DataGridTextColumn Header="Thành tiền"
                                    Binding="{Binding FinalAmount}"
                                    Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
